}

function init_compuzone_pay(customerKey){
	if(Object.keys(connect_pay).length < 1){ // 객체 생성 전에만 타도록
		var clientKey = 'live_ck_YoEjb0gm23PG1qRdXXW8pGwBJn5e';	// client key는 공개 가능키(결제창 오픈)
		
		// test 
		if(window.location.hostname == 'www3.compuzone.co.kr' || window.location.hostname == 'www.dev.coz'){
			clientKey = 'test_ck_Kma60RZblrqlk76DoLRVwzYWBn14';		
		}
		
		var endpoint = window.location.protocol + "//" + window.location.hostname;
		connect_pay = ConnectPay(clientKey,customerKey,{
			redirectUrl: endpoint + '/compuzonepay/compuzonepay_auth.php/authorization',
			ui : {
