				buttonStyle: 'default'
			}
		});	
	}
}

function get_compuzone_pay_account(){		
	return new Promise(function(resolve, reject) {		
		connect_pay.getPaymentMethods()
		.then(function(methods){
			resolve(methods);
		})
		.catch(function(error){
			if(error.code == 'NEED_AGREEMENT_WITH_TERMS'){		
				resolve(error.code);
			}else{
				reject(error.message);
			}
		});		
	});
}

function set_compuzone_pay_account(mid){
	init_compuzone_pay(mid);

	connect_pay.addPaymentMethod()
  .then(function (methods) {
  	var last_reg_method = '';
  	var compare_reg_at = '';
  	
  	$.each(methods, function(key, value){ 
		  $.each(value, function(idx, payments){
		  	var reg_at = payments['registeredAt'];
		  	if(!compare_reg_at){
		  		compare_reg_at = reg_at;
		  		last_reg_method = payments['id'];
		  	}else{
		  		if(compare_reg_at < reg_at){
		  			compare_reg_at = reg_at;	
		  			last_reg_method = payments['id'];	  		
		  		}
		  	}
		  });
		});
  	
  	if(last_reg_method){
  		$('#SelectCpayMethodID').val(last_reg_method);	
  	} 
  	
  	document.getElementById('PreCheckedAccount').value = '1';
  	setWhichPayment('11');
    // 성공 처리
  })
  .catch(function (error) {
    if (error.code === 'USER_CANCEL') {
      // 사용자가 결제창을 닫은 경우 에러 처리
    }
  })
}

